# Next-Bet-AI backend
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
UVICORN_RELOAD=false

# Database
DB_URL_POOLER=
DB_URL=

# Public site and CORS
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Admin routes: send this value as the x-admin-api-key header.
ADMIN_API_KEY=
ENABLE_API_DOCS=false
ALLOW_PUBLIC_BLOCKING_REFRESH=false

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_LIGUE1_MONTHLY=
STRIPE_PRICE_LIGUE1_YEARLY=
STRIPE_PRICE_PL_MONTHLY=
STRIPE_PRICE_PL_YEARLY=
STRIPE_PRICE_ULTIMATE_MONTHLY=
STRIPE_PRICE_ULTIMATE_YEARLY=

# Football data providers
ODDS_API_KEY=
API_FOOTBALL_KEY=

# Prediction cache tuning
UPCOMING_CACHE_TTL_SECONDS=90
UPCOMING_STALE_TTL_SECONDS=1800
UPCOMING_MAX_LIMIT=300
UPCOMING_PREWARM_LIMIT=300
UPCOMING_PREWARM_ON_STARTUP=true
